---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ArticleList from "../components/ArticleList.astro";

export interface Props {
	title: string;
	description: string;
	categorySlug: string;
	posts: any[];
}

const { title, description, posts, categorySlug } = Astro.props;

// Filter posts by category
const categoryPosts = categorySlug
	? posts.filter((post) => post.data.categorySlug === categorySlug)
	: posts;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}

			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.section-header {
				margin-bottom: 2em;
				text-align: center;
			}

			/* Dark mode styles for header */
			:global(.dark-mode) .section-header h1 {
				color: #ffffff;
			}

			:global(.dark-mode) .section-header p {
				color: #b0b6c6;
			}

			/* System preference dark mode for header */
			@media (prefers-color-scheme: dark) {
				:global(:not(.light-mode):not(.dark-mode)) .section-header h1 {
					color: #ffffff;
				}

				:global(:not(.light-mode):not(.dark-mode)) .section-header p {
					color: #b0b6c6;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="prose">
					<div class="title">
						<h2>{title}</h2>
						<meta name="description" content={description} />
						<hr />
					</div>

					<!-- Use the ArticleList component -->
					<ArticleList posts={categoryPosts} />
				</div>
			</section>
			<Footer />
		</main>
	</body>
</html>
